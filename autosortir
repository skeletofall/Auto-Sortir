#!/usr/bin/env python3
# -*- coding: utf-8 -*-
import os
import shutil
from pathlib import Path
import logging
from datetime import datetime
import json

def load_config():
    config_path = Path(__file__).parent / "config.json"
    if not config_path.exists():
        logging.error(f"Конфигурационный файл не найден: {config_path}")
        return None

    try:
        with open(config_path, 'r', encoding='utf-8') as f:
            config = json.load(f)
        return config
    except Exception as e:
        logging.error(f"Ошибка при чтении конфига: {e}")
        return None

def setup_logging(target_dir):
    log_file = target_dir / "auto_organizer.log"
    logging.basicConfig(
        level=logging.INFO,
        format='%(asctime)s - %(levelname)s - %(message)s',
        handlers=[
            logging.FileHandler(log_file, encoding='utf-8'),
            logging.StreamHandler()
        ]
    )

def get_file_category(file_extension, categories):
    for category, extensions in categories.items():
        if file_extension.lower() in extensions:
            return category
    return 'Other'

def organize_downloads(config):
    target_dir_str = config.get('target_directory', '~/Downloads')
    target_path = Path(target_dir_str).expanduser()

    if not target_path.exists():
        logging.error(f"Папка {target_path} не найдена!")
        return

    categories = config.get('categories', {})
    processed_count = 0
    skipped_count = 0

    for item in target_path.iterdir():
        if item.is_dir() or item.name.startswith('.') or item.name == 'auto_organizer.log':
            continue

        file_extension = item.suffix
        category = get_file_category(file_extension, categories)

        category_path = target_path / category
        category_path.mkdir(exist_ok=True)

        destination = category_path / item.name
        counter = 1
        while destination.exists():
            stem = item.stem
            new_name = f"{stem}_{counter}{item.suffix}"
            destination = category_path / new_name
            counter += 1

        try:
            shutil.move(str(item), str(destination))
            logging.info(f"Перемещен: {item.name} -> {category}/")
            processed_count += 1
        except Exception as e:
            logging.error(f"Ошибка при перемещении {item.name}: {e}")
            skipped_count += 1

    preserve_folders = list(categories.keys()) + ['Other']
    for folder in target_path.iterdir():
        if folder.is_dir() and folder.name not in preserve_folders:
            try:
                if not any(folder.iterdir()):
                    folder.rmdir()
                    logging.info(f"Удалена пустая папка: {folder.name}")
            except Exception as e:
                logging.error(f"Ошибка при удалении папки {folder.name}: {e}")

    logging.info(f"Готово! Обработано: {processed_count}, Пропущено: {skipped_count}")

if __name__ == "__main__":
    print("🚀 Запуск автосортировщика файлов...")
    print(f"Время начала: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}")
    print("-" * 50)

    config = load_config()
    if not config:
        print("❌ Не удалось загрузить конфигурацию!")
        input("Нажмите Enter для выхода...")
        exit(1)

    target_dir = Path(config.get('target_directory', '~/Downloads')).expanduser()
    setup_logging(target_dir)
    organize_downloads(config)

    print("-" * 50)
    print("✅ Сортировка завершена!")
    input("Нажмите Enter для выхода...")